Options -Indexes
RewriteEngine On

# Redireciona para /public_html evitando loop e ignorando arquivos/diretórios existentes
RewriteCond %{REQUEST_URI} !^/public_html/
RewriteCond %{REQUEST_URI} !^/institutodona/public_html/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public_html/$1 [L]